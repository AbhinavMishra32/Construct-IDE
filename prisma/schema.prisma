generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ConstructState {
  key       String   @id
  valueJson String   @map("value_json") @db.Text
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("construct_state")
}

model User {
  id           String               @id
  email        String               @unique
  displayName  String               @map("display_name")
  avatarUrl    String?              @map("avatar_url")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLoginAt  DateTime?            @map("last_login_at") @db.Timestamptz(6)

  passwordCredential PasswordCredential?
  authSessions        AuthSession[]
  authIdentities      AuthIdentity[]
  providerConnections ProviderConnection[]
  apiUsageEvents      ApiUsageEvent[]

  @@map("construct_users")
}

model PasswordCredential {
  userId       String   @id @map("user_id")
  passwordHash String   @map("password_hash")
  passwordSalt String   @map("password_salt")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("construct_password_credentials")
}

model AuthSession {
  id        String    @id
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastSeenAt DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([userId, expiresAt])
  @@map("construct_auth_sessions")
}

model AuthIdentity {
  id             String    @id
  userId         String    @map("user_id")
  provider       String
  providerUserId String    @map("provider_user_id")
  email          String?
  displayName    String?   @map("display_name")
  accessTokenEncrypted  String? @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String? @map("refresh_token_encrypted") @db.Text
  scopesJson     String    @default("[]") @map("scopes_json") @db.Text
  metadataJson   String?   @map("metadata_json") @db.Text
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz(6)
  linkedAt       DateTime  @default(now()) @map("linked_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId, provider])
  @@map("construct_auth_identities")
}

model ProviderConnection {
  id                    String    @id
  userId                String    @map("user_id")
  provider              String
  authType              String    @map("auth_type")
  status                String
  label                 String    @default("")
  hasSecret             Boolean   @default(false) @map("has_secret")
  secretEncrypted       String?   @map("secret_encrypted") @db.Text
  refreshTokenEncrypted String?   @map("refresh_token_encrypted") @db.Text
  last4                 String?   @map("last4")
  baseUrl               String?   @map("base_url")
  externalAccountId     String?   @map("external_account_id")
  externalEmail         String?   @map("external_email")
  scopesJson            String    @default("[]") @map("scopes_json") @db.Text
  metadataJson          String?   @map("metadata_json") @db.Text
  expiresAt             DateTime? @map("expires_at") @db.Timestamptz(6)
  lastValidatedAt       DateTime? @map("last_validated_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider, authType])
  @@index([userId, provider])
  @@map("construct_provider_connections")
}

model ApiUsageEvent {
  id                String   @id
  userId            String   @map("user_id")
  provider          String
  kind              String   @default("llm")
  model             String
  operation         String
  stage             String?
  schemaName        String?  @map("schema_name")
  mode              String?
  projectId         String?  @map("project_id")
  projectName       String?  @map("project_name")
  projectGoal       String?  @map("project_goal") @db.Text
  buildId           String?  @map("build_id")
  sessionId         String?  @map("session_id")
  jobId             String?  @map("job_id")
  inputTokens       Int      @default(0) @map("input_tokens")
  outputTokens      Int      @default(0) @map("output_tokens")
  totalTokens       Int      @default(0) @map("total_tokens")
  cachedInputTokens Int      @default(0) @map("cached_input_tokens")
  reasoningTokens   Int      @default(0) @map("reasoning_tokens")
  costUsd           Float?   @map("cost_usd")
  currency          String?
  metadataJson      String?  @map("metadata_json") @db.Text
  recordedAt        DateTime @default(now()) @map("recorded_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId, provider, recordedAt])
  @@index([userId, projectId, recordedAt])
  @@index([userId, buildId, recordedAt])
  @@map("construct_api_usage_events")
}

model Project {
  id               String        @id @map("session_id")
  userId           String        @default("local-user") @map("user_id")
  goal             String
  blueprintId      String        @map("blueprint_id")
  blueprintPath    String        @unique @map("blueprint_path")
  projectRoot      String        @map("project_root")
  blueprintJson    String        @map("blueprint_json") @db.Text
  planJson         String        @map("plan_json") @db.Text
  bundleJson       String        @map("bundle_json") @db.Text
  name             String        @default("")
  slug             String        @default("")
  description      String        @default("")
  language         String        @default("")
  currentStepId    String?       @map("current_step_id")
  currentStepTitle String?       @map("current_step_title")
  currentStepIndex Int?          @map("current_step_index")
  totalSteps       Int           @default(0) @map("total_steps")
  completedStepIds String        @default("[]") @map("completed_step_ids") @db.Text
  status           String        @default("IN_PROGRESS")
  lastAttemptStatus String?      @map("last_attempt_status")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastOpenedAt     DateTime?     @map("last_opened_at") @db.Timestamptz(6)
  isActive         Boolean       @default(false) @map("is_active")

  @@index([userId, isActive])
  @@index([userId, updatedAt])
  @@index([userId, lastOpenedAt])
  @@map("construct_blueprints")
}

model BlueprintBuild {
  id                 String                @id
  sessionId          String?               @unique @map("session_id")
  userId             String                @default("local-user") @map("user_id")
  goal               String
  detectedLanguage   String?               @map("detected_language")
  detectedDomain     String?               @map("detected_domain")
  status             String
  currentStage       String?               @map("current_stage")
  currentStageTitle  String?               @map("current_stage_title")
  currentStageStatus String?               @map("current_stage_status")
  lastError          String?               @map("last_error") @db.Text
  langSmithProject   String?               @map("langsmith_project")
  traceUrl           String?               @map("trace_url") @db.Text
  planningSessionJson String?              @map("planning_session_json") @db.Text
  answersJson        String                @default("[]") @map("answers_json") @db.Text
  planJson           String?               @map("plan_json") @db.Text
  blueprintJson      String?               @map("blueprint_json") @db.Text
  blueprintDraftJson String?               @map("blueprint_draft_json") @db.Text
  supportFilesJson   String                @default("[]") @map("support_files_json") @db.Text
  canonicalFilesJson String                @default("[]") @map("canonical_files_json") @db.Text
  learnerFilesJson   String                @default("[]") @map("learner_files_json") @db.Text
  hiddenTestsJson    String                @default("[]") @map("hidden_tests_json") @db.Text
  createdAt          DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt        DateTime?             @map("completed_at") @db.Timestamptz(6)
  lastEventAt        DateTime?             @map("last_event_at") @db.Timestamptz(6)

  stages             BlueprintBuildStage[]
  events             BlueprintBuildEvent[]

  @@index([userId, updatedAt])
  @@index([userId, status])
  @@index([userId, lastEventAt])
  @@map("construct_blueprint_builds")
}

model BlueprintBuildStage {
  id          String          @id
  buildId     String          @map("build_id")
  stage       String
  title       String
  status      String
  detail      String?         @db.Text
  inputJson   String?         @map("input_json") @db.Text
  outputJson  String?         @map("output_json") @db.Text
  metadataJson String?        @map("metadata_json") @db.Text
  traceUrl    String?         @map("trace_url") @db.Text
  startedAt   DateTime        @map("started_at") @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  completedAt DateTime?       @map("completed_at") @db.Timestamptz(6)

  build       BlueprintBuild  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@unique([buildId, stage])
  @@index([buildId, updatedAt])
  @@map("construct_blueprint_build_stages")
}

model BlueprintBuildEvent {
  id         String          @id
  buildId    String          @map("build_id")
  jobId      String?         @map("job_id")
  kind       String?
  stage      String
  title      String
  detail     String?         @db.Text
  level      String
  payloadJson String?        @map("payload_json") @db.Text
  traceUrl   String?         @map("trace_url") @db.Text
  timestamp  DateTime        @db.Timestamptz(6)

  build      BlueprintBuild  @relation(fields: [buildId], references: [id], onDelete: Cascade)

  @@index([buildId, timestamp])
  @@map("construct_blueprint_build_events")
}
