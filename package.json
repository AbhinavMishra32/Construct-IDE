{
  "name": "construct",
  "private": true,
  "version": "0.2.1",
  "packageManager": "pnpm@10.23.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@types/react": "^19.2.16",
      "@types/react-dom": "^19.2.3"
