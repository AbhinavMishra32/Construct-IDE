::file path="include/tensor.hpp"
```cpp
#pragma once

#include <cstdint>
#include <vector>

class Tensor {
public:
  explicit Tensor(std::vector<int64_t> shape);

  const std::vector<int64_t>& sizes() const;
  int64_t numel() const;

private:
  std::vector<int64_t> shape_;
};
```
::end

::file path="src/tensor.cpp"
```cpp
#include "tensor.hpp"

Tensor::Tensor(std::vector<int64_t> shape) : shape_(std::move(shape)) {}

const std::vector<int64_t>& Tensor::sizes() const {
  return shape_;
}
```
::end

::file path="src/main.cpp"
```cpp
#include "tensor.hpp"

#include <iostream>
#include <string>

int main(int argc, char** argv) {
  const bool smokeTensor = argc > 1 && std::string(argv[1]) == "--smoke-tensor";

  if (smokeTensor) {
    Tensor t({2, 3, 4});
    // TODO: print the tensor scalar count through the Tensor API.
    return 0;
  }

  std::cout << "inferlab ready\n";
  return 0;
}
