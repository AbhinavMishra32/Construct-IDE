# Local sample environment for Construct.
# Replace these placeholders with real keys before using the real agent stack.

CONSTRUCT_RUNNER_PORT=43110
CONSTRUCT_AGENT_PROVIDER=openrouter
CONSTRUCT_SEARCH_PROVIDER=tavily
CONSTRUCT_OPENROUTER_MODEL=openrouter/owl-alpha
CONSTRUCT_OPENROUTER_FAST_MODEL=openrouter/owl-alpha
CONSTRUCT_OPENROUTER_REPAIR_MODEL=openrouter/owl-alpha
CONSTRUCT_TAVILY_SEARCH_DEPTH=advanced
CONSTRUCT_DEBUG_LEVEL=1
CONSTRUCT_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
TAVILY_API_KEY=
CONSTRUCT_STORAGE_BACKEND=prisma
CONSTRUCT_USER_ID=local-user
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="CONSTRUCT"

CONSTRUCT_DEBUG_MODE=1
