# Construct backend runner environment.
# Desktop app behavior is configured through Construct settings and the
# OS-backed construct.config.json file, not through .env.

CONSTRUCT_RUNNER_PORT=43110

# Persistence backend. Set to prisma to store auth, planning state, knowledge,
# projects, and generated blueprints through Prisma.
CONSTRUCT_STORAGE_BACKEND=prisma
CONSTRUCT_USER_ID=local-user
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Optional. If omitted, Construct generates a local machine secret under
# .construct/state/ to encrypt saved provider credentials.
CONSTRUCT_APP_SECRET=replace-with-a-long-random-secret

# AI provider, model, runtime, endpoint, and key values belong in Construct's
# Settings screen. The desktop app migrates old construct-projects/settings.json
# into construct.config.json and obeys that config as the source of truth.
